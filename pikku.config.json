{
  "$schema": "https://raw.githubusercontent.com/pikkujs/pikku/refs/heads/main/packages/cli/cli.schema.json",
  "tsconfig": "./tsconfig.json",
  "srcDirectories": ["src"],
  "outDir": ".pikku",
  "verboseMeta": true,
  "console": true,
  "openAPI": {
    "outputFile": "openapi.yml",
    "additionalInfo": {
      "info": {
        "title": "Engineering Platform API",
        "version": "1.0.0",
        "description": "Demo engineering platform API"
      },
      "servers": [
        { "url": "http://localhost:3000", "description": "Development" }
      ],
      "securitySchemes": {
        "CookieAuth": {
          "type": "apiKey",
          "in": "cookie",
          "name": "authjs.session-token"
        }
      },
      "security": [{ "CookieAuth": [] }]
    }
  }
}
